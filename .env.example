# ============================================
# REPLACE THESE PLACEHOLDER VALUES
# ============================================

# MongoDB connection string — replace with your Atlas URI or local URI
# Local example:   mongodb://127.0.0.1:27017/vehicle_tracker
# Atlas example:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/vehicle_tracker
MONGO_URI=mongodb://127.0.0.1:27017/vehicle_tracker

# RTO API placeholder — swap for a real provider (Surepass, Signzy, RapidAPI vendor, etc.)
RTO_API_URL=https://api.placeholder-rto.com/v1/vehicle
RTO_API_KEY=YOUR_RTO_API_KEY_HERE

# ESP32-CAM IP address on your local Wi-Fi (printed in Serial Monitor on boot)
ESP32_CAM_IP=192.168.1.50

# Server port
PORT=3000

# Authorization rule: vehicle is unauthorized if registration is older than this many years
MAX_VEHICLE_AGE_YEARS=15
