# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/vehicle_tracker

# FireAPI RTO lookup
RTO_API_URL=https://api.fireapi.io/secure-app/rc-vehicle-info/v1
RTO_API_KEY=YOUR_FIREAPI_KEY_HERE

# Python PaddleOCR sidecar (primary OCR)
PYTHON_OCR_URL=http://127.0.0.1:5001

# Plate Recognizer cloud API (fallback when PaddleOCR finds nothing)
# Free tier: 2500 calls/month. Get token at https://platerecognizer.com
PLATE_RECOGNIZER_TOKEN=YOUR_PLATE_RECOGNIZER_TOKEN_HERE
PLATE_RECOGNIZER_REGIONS=in

# ESP32-CAM IP
ESP32_CAM_IP=192.168.1.50

# Server
PORT=3000

# Authorization rule
MAX_VEHICLE_AGE_YEARS=15
