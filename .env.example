# ============================================
# REPLACE THESE PLACEHOLDER VALUES
# ============================================

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/vehicle_tracker

# FireAPI RTO lookup (the only external API call)
RTO_API_URL=https://api.fireapi.io/secure-app/rc-vehicle-info/v1
RTO_API_KEY=YOUR_FIREAPI_KEY_HERE

# Python PaddleOCR sidecar (default works if you run it on the same machine)
PYTHON_OCR_URL=http://127.0.0.1:5001

# ESP32-CAM IP on local Wi-Fi (printed in Serial Monitor on boot)
ESP32_CAM_IP=192.168.1.50

# Server
PORT=3000

# Authorization rule
MAX_VEHICLE_AGE_YEARS=15
