{
  "name": "vehicle-tracker",
  "version": "1.0.0",
  "description": "ESP32-CAM based real-time vehicle number plate tracker with RTO verification",
  "main": "backend/server.js",
  "scripts": {
    "setup:python": "node scripts/run-python.js setup",
    "setup": "npm install && npm run setup:python",
    "start:node": "node backend/server.js",
    "start:python": "node scripts/run-python.js",
    "start": "concurrently --names \"NODE,OCR\" --prefix-colors \"yellow,cyan\" --kill-others-on-fail \"npm:start:node\" \"npm:start:python\"",
    "dev": "concurrently --names \"NODE,OCR\" --prefix-colors \"yellow,cyan\" --kill-others-on-fail \"nodemon backend/server.js\" \"npm:start:python\""
  },
  "dependencies": {
    "axios": "^1.6.7",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "form-data": "^4.0.0",
    "mongoose": "^8.2.1",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
